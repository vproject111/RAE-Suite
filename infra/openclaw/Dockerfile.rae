FROM node:22-bookworm-slim
WORKDIR /app
ENV CI=true
RUN apt-get update && apt-get install -y git && npm install -g pnpm
COPY . .
RUN pnpm install --ignore-scripts
RUN pnpm build
# Use built artifacts
CMD ["node", "openclaw.mjs", "gateway", "--bind", "lan", "--port", "18789", "--allow-unconfigured"]
